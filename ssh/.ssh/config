Host *
  IdentitiesOnly yes

Match host="github.com" exec "uname | grep -q Darwin"
  HostName github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/lehtope2.ed
  user git

Host github.com
  HostName github.com
  AddKeysToAgent yes
  IdentityFile ~/.ssh/lehtope2.ed
  user git

Match host="github.personal.com" exec "uname | grep -q Darwin"
  HostName github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/pjl.rsa
  user git

Host github.personal.com
  HostName github.com
  AddKeysToAgent yes
  IdentityFile ~/.ssh/pjl.rsa
  user git

alias cl=clear
if [[ $OSTYPE == darwin* ]]; then
  alias ls='ls -G'
else
  alias ls='ls --color=auto'
fi
alias ll='ls -l'
alias la='ls -a'
alias lal='ls -al'
alias vim=nvim
alias vi=nvim

# Platform-aware clipboard
if [[ $OSTYPE == darwin* ]]; then
  alias clip=pbcopy
elif command -v wl-copy &>/dev/null; then
  alias clip=wl-copy
else
  alias clip='xclip -selection clipboard'
fi

alias -g CP="|clip"
alias -g L="|less"
alias -g F="|fzf"
alias zs='echo ''Sourcing .zshrc''; source ~/.zshrc'

# Git
alias glt='git log --oneline --max-count 20'
alias gst='git status'
alias groot='cd $(git root)'

# Lookup my external IP address
alias myip='if [[ $OSTYPE == darwin* ]]; then echo -n $(curl -s ipinfo.io/ip) | clip; else curl -s ipinfo.io/ip; fi'


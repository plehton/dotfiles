# set default java version
function jdk {
      local version=$1

      if [[ -z $version ]]; then
        echo "Usage: jdk <version>" >&2
        return 1
      fi

      unset JAVA_HOME
      if [[ $OSTYPE == darwin* ]]; then
        export JAVA_HOME=$(/usr/libexec/java_home -v"$version" 2>/dev/null)
        if [[ -z $JAVA_HOME ]]; then
          echo "No JDK found for version $version" >&2
          return 1
        fi
      else
        # Linux fallback: manually pick JDK from /usr/lib/jvm
        local jdks=(/usr/lib/jvm/java-${version}-*(N))
        if [[ ${#jdks} -gt 0 ]]; then
          export JAVA_HOME=${jdks[1]}
        else
          echo "No JDK found for version $version" >&2
          return 1
        fi
      fi
      java -version
}

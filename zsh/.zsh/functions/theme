function theme {

    local COLORSCHEME=$1
    local ghostty_theme_dir=$HOME/.config/ghostty/auto
    local ghostty_theme_cfg=$ghostty_theme_dir/theme.ghostty

    local current_scheme=$(< $HOME/.colorscheme 2>/dev/null)

    # When theme is run without parameters, just report current theme
    if [[ ! -n $COLORSCHEME ]]; then
        echo "Current color scheme is '$current_scheme'."
        return 0
    fi

    # Given theme equals current > don't do anything
    if [[ "$current_scheme" == "$COLORSCHEME" ]]; then
        echo "'$COLORSCHEME' already in use."
        return 0
    fi

    print -r -- "$COLORSCHEME" >$HOME/.colorscheme

    # Update Ghostty config and reload
    if [[ -d $HOME/.config/ghostty ]]; then
        mkdir -p "$ghostty_theme_dir"
        print -r -- "theme = $COLORSCHEME" >"$ghostty_theme_cfg"

        if [[ $OSTYPE == darwin* ]]; then
            killall -USR1 ghostty 2>/dev/null && echo "Ghostty reloaded." || echo "Ghostty theme updated; reload terminal to apply."
        fi
    fi
}
